# Example environment configuration for invision-backend
# Copy this file to .env and fill in real secrets before running.

# Server
PORT=3000
NODE_ENV=development

# MongoDB connection string (including DB name)
# Example: mongodb://localhost:27017/invision-db
MONGODB_URI=

# JWT secret used to sign access tokens.
# Generate a strong secret, e.g. `openssl rand -hex 32`
JWT_SECRET=
JWT_EXPIRES_IN=1h

# CORS: allowed origin for the frontend (Next.js app). For multiple origins use comma separation.
CORS_ORIGIN=http://localhost:3000

# Bcrypt salt rounds for hashing passwords (recommended: 10-12)
SALT_ROUNDS=12

# Rate limit settings (optional)
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW_MS=60000

